{
  "expo": {
    "name": "ENDOPAMIN",
    "slug": "endopamin-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "endopamin",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000"
      }
    },
    "plugins": [
      "expo-secure-store",
      "@stripe/stripe-react-native"
    ]
  }
}
