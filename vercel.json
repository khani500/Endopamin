{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron-notify",
      "schedule": "0 18 * * *"
    }
  ],
  "functions": {
    "api/gemini.js": {
      "maxDuration": 30
    }
  }
}
